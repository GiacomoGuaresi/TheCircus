{
  "name": "the-circus",
  "version": "0.1.0",
  "description": "AI-powered desktop wallpaper generator with evolving characters",
  "main": "out/main/index.js",
  "author": "Ginger Additive",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "generate": "tsx src/scripts/generate.ts",
    "create-example-character": "tsx src/scripts/createExampleCharacter.ts",
    "validate-data": "tsx src/scripts/validateData.ts",
    "reset-config": "tsx src/scripts/resetConfig.ts",
    "reset-data": "tsx src/scripts/resetData.ts",
    "backup-data": "tsx src/scripts/backupData.ts",
    "logs": "tsx src/scripts/viewLogs.ts",
    "clean": "rimraf out",
    "clean:all": "rimraf out node_modules"
  },
  "dependencies": {
    "electron": "^27.3.11",
    "dotenv": "^16.4.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "node-cron": "^3.0.3",
    "fs-extra": "^11.2.0",
    "zod": "^3.23.8",
    "sharp": "^0.33.4",
    "p-queue": "^8.0.1",
    "axios": "^1.7.9",
    "groq-sdk": "^0.7.0",
    "@google/generative-ai": "^0.21.0",
    "wallpaper": "^4.1.0",
    "uuid": "^10.0.0",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "tailwindcss": "^3.4.17",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49"
  }
}
