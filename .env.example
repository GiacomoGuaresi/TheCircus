# ─── AI Image Generation Providers ───────────────────────────────────────────
# Scegli un provider e inserisci la relativa chiave.
# Il provider attivo si configura in config/config.default.json → ai_image.provider

# Pollinations.ai — GRATUITO, nessuna chiave necessaria
# Funziona out-of-the-box, ottimo per iniziare.

# Hugging Face — FREE tier generoso (crea account su https://huggingface.co)
# → Crea token su: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_hf_token_here

# Stability.ai — A pagamento (crediti, ~$0.01/immagine)
# → Crea chiave su: https://platform.stability.ai/account/keys
STABILITY_API_KEY=your_stability_key_here

# Replicate — Free tier limitato, poi a pagamento
# → Crea token su: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_token_here

# ─── AI Language Model Providers ──────────────────────────────────────────────
# Usato per generare gli scenari. Scegli un provider.
# Il provider attivo si configura in config/config.default.json → ai_llm.provider

# Groq — FREE tier molto generoso (vedi: https://console.groq.com)
# Modelli disponibili: llama-3.3-70b-versatile, mixtral-8x7b, gemma2-9b
# → Crea chiave su: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Google Gemini — FREE tier: 1M token/giorno con Gemini 1.5 Flash
# → Crea chiave su: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# OpenRouter — Aggregatore con alcuni modelli gratuiti
# → Crea chiave su: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Ollama — GRATUITO, gira in locale (nessuna chiave, nessun limite)
# → Installa da: https://ollama.ai
# → Poi esegui: ollama pull llama3.2
# → Il server parte automaticamente con: ollama serve
OLLAMA_BASE_URL=http://localhost:11434

# ─── App ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
